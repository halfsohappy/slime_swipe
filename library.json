{
  "name": "SlimeIMU",
  "version": "1.0.0",
  "description": "High-quality IMU sensor fusion library for ESP32, extracted from SlimeVR firmware. Features VQF sensor fusion, auto-detection, calibration persistence, and support for BMI160, BMI270, ICM42688, ICM45xxx, LSM6DSx, MPU6050, BNO0xx, and more.",
  "keywords": "imu, sensor fusion, vqf, quaternion, gyroscope, accelerometer, magnetometer, bmi270, icm42688, lsm6dsv, mpu6050, bno085, esp32, motion tracking, orientation",
  "repository": {
    "type": "git",
    "url": "https://github.com/halfsohappy/slime_swipe.git"
  },
  "authors": [
    {
      "name": "SlimeVR Contributors",
      "url": "https://slimevr.dev"
    }
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": [
    "espressif32"
  ],
  "headers": "SlimeIMU.h",
  "build": {
    "srcFilter": [
      "+<*>",
      "+<../lib/math>",
      "+<../lib/bno080>",
      "+<../lib/i2cdev>",
      "+<../lib/i2cscan>",
      "+<../lib/vqf>",
      "+<../lib/magneto>",
      "+<../lib/bno055_adafruit>",
      "+<../lib/mpu6050>",
      "+<../lib/mpu6050offsetfinder>",
      "+<../lib/mpu9250>",
      "+<../lib/ICM20948>",
      "+<../lib/magnetometers>",
      "-<../examples>"
    ],
    "flags": [
      "-std=gnu++2a",
      "-O2",
      "-Ilib/math",
      "-Ilib/bno080",
      "-Ilib/i2cdev",
      "-Ilib/i2cscan",
      "-Ilib/vqf",
      "-Ilib/magneto",
      "-Ilib/bno055_adafruit",
      "-Ilib/mpu6050",
      "-Ilib/mpu6050offsetfinder",
      "-Ilib/mpu9250",
      "-Ilib/ICM20948",
      "-Ilib/magnetometers"
    ],
    "unflags": [
      "-std=gnu++11",
      "-std=gnu++17"
    ]
  },
  "dependencies": {
    "adafruit/Adafruit MCP23017 Arduino Library": "*",
    "hideakitai/PCA9547": "*"
  },
  "examples": [
    "examples/basic_imu/main.cpp",
    "examples/calibration/main.cpp",
    "examples/multi_sensor/main.cpp"
  ]
}
